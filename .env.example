# Wub Hair frontend configuration
# Copy this file to .env and fill in the values for your environment.
#
# Database credentials do NOT belong here - anything prefixed VITE_ is
# bundled into the public JS and shipped to every visitor's browser. All
# database/API secrets live only in server/.env (see server/.env.example).

# URL of the deployed Express API (server/) - e.g. https://wubhair-api.onrender.com
# in production, or http://localhost:3001 for local development.
VITE_API_URL=http://localhost:3001
