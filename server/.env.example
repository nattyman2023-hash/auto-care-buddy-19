# Wub Hair API server environment configuration
# Copy this file to .env (local dev) or set these as environment variables in
# your Render service settings (production). Never commit real values.

PORT=3001

# MySQL database connection (Hostinger) - enable "Remote MySQL" in hPanel and
# allow-list your API server's outbound IP so it can reach this database.
DB_HOST=your-hostinger-db-host
DB_PORT=3306
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_SSL=true

# Auth - generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Used to build links in emails (password reset, invites, unsubscribe)
FRONTEND_URL=https://your-domain.com

# Transactional email (Resend) - leave unset to have emails logged instead of sent
RESEND_API_KEY=
EMAIL_FROM="Wub Hair <notifications@your-domain.com>"

# AI chat assistant (Anthropic)
ANTHROPIC_API_KEY=

# Signed storage URLs (expense receipts) - defaults to JWT_SECRET if unset
STORAGE_SIGN_SECRET=
